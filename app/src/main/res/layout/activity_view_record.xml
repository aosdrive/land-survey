<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EEF2F0">

    <!-- ===== NEW survey: single beautiful card ===== -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:padding="12dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="18dp"
            app:cardElevation="3dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- ===== HEADER ===== -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_card_header"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="18dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:alpha="0.85"
                            android:text="Parcel No"
                            android:textColor="#FFFFFF"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tvParcelNo"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#FFFFFF"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            tools:text="775 / 2" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_status_pill"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="5dp"
                        android:textColor="#0F6E56"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        tools:text="Surveyed" />
                </LinearLayout>

                <!-- ===== METRIC TILES ===== -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:weightSum="2">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_metric_tile"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Calculated Area"
                            android:textColor="#667085"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/tvArea"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:textColor="#101828"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            tools:text="2.84 Acres" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_metric_tile"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Year"
                            android:textColor="#667085"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/tvYear"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:textColor="#101828"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            tools:text="2026" />
                    </LinearLayout>
                </LinearLayout>

                <!-- ===== SURVEY DETAILS ===== -->
                <TextView
                    style="@style/VrSectionLabel"
                    android:text="Survey Details" />

                <LinearLayout
                    android:id="@+id/containerSurvey"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="18dp"
                    android:paddingBottom="6dp" />

                <!-- ===== OWNER INFO ===== -->
                <View style="@style/VrDivider" />

                <TextView
                    android:id="@+id/tvOwnersLabel"
                    style="@style/VrSectionLabel"
                    android:text="Owner Information" />

                <LinearLayout
                    android:id="@+id/containerOwners"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="18dp"
                    android:paddingBottom="6dp" />

                <!-- ===== IMAGES ===== -->
                <View
                    android:id="@+id/dividerImages"
                    style="@style/VrDivider" />

                <TextView
                    android:id="@+id/tvImagesLabel"
                    style="@style/VrSectionLabel"
                    android:text="Images" />

                <LinearLayout
                    android:id="@+id/containerImages"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="18dp"
                    android:paddingBottom="18dp">

                    <!-- Parcel pics -->
                    <TextView
                        android:id="@+id/tvParcelPicLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        android:text="Parcel Pictures"
                        android:textColor="#667085"
                        android:textSize="12sp"
                        android:visibility="gone"
                        tools:visibility="visible" />

                    <HorizontalScrollView
                        android:id="@+id/scrollParcelPics"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:scrollbars="none"
                        android:visibility="gone"
                        tools:visibility="visible">

                        <LinearLayout
                            android:id="@+id/rowParcelPics"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal" />
                    </HorizontalScrollView>

                    <!-- Farmer pic -->
                    <TextView
                        android:id="@+id/tvFarmerPicLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:layout_marginBottom="6dp"
                        android:text="Farmer Picture"
                        android:textColor="#667085"
                        android:textSize="12sp"
                        android:visibility="gone"
                        tools:visibility="visible" />

                    <ImageView
                        android:id="@+id/ivFarmerPic"
                        android:layout_width="120dp"
                        android:layout_height="120dp"
                        android:background="@drawable/bg_image_placeholder"
                        android:scaleType="centerCrop"
                        android:visibility="gone"
                        tools:src="@tools:sample/avatars"
                        tools:visibility="visible" />
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </androidx.core.widget.NestedScrollView>

    <!-- ===== OLD survey legacy recycler (unchanged flow) ===== -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="12dp"
        android:visibility="gone"
        tools:listitem="@layout/card_view_record" />

    <!-- Header text kept for OLD flow (hidden in new) -->
    <TextView
        android:id="@+id/tv_details"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/listitem_text_activated"
        android:gravity="center"
        android:minHeight="50dp"
        android:padding="10dp"
        android:textColor="@color/black"
        android:textSize="14sp"
        android:visibility="gone" />

    <!-- Empty state -->
    <TextView
        android:id="@+id/noRecordText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:text="@string/no_records_to_display"
        android:textColor="#667085"
        android:textSize="15sp"
        android:visibility="gone" />

</FrameLayout>