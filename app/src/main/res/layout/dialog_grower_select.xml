<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#1B5E20"
        android:padding="18dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select Grower"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvGrowerCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="#C8E6C9"
            android:textSize="13sp" />
    </LinearLayout>

    <!-- Search box -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="14dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp"
        xmlns:app="http://schemas.android.com/apk/res-auto">

        <EditText
            android:id="@+id/etSearch"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="Search by name, CNIC, passbook…"
            android:textColorHint="#9E9E9E"
            android:textColor="#212121"
            android:textSize="15sp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:background="@android:color/transparent"
            android:inputType="text"
            android:maxLines="1"
            android:imeOptions="actionSearch" />
    </androidx.cardview.widget.CardView>

    <!-- List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvGrowers"
        android:layout_width="match_parent"
        android:layout_height="420dp"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp"
        android:clipToPadding="false"
        android:paddingBottom="8dp"
        android:scrollbars="vertical" />

    <!-- Empty state -->
    <TextView
        android:id="@+id/tvEmpty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No growers match your search"
        android:textColor="#9E9E9E"
        android:textSize="14sp"
        android:gravity="center"
        android:padding="24dp"
        android:visibility="gone" />

    <!-- Cancel -->
    <TextView
        android:id="@+id/btnCancelGrower"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="CANCEL"
        android:textColor="#1B5E20"
        android:textSize="15sp"
        android:textStyle="bold"
        android:gravity="center"
        android:padding="16dp"
        android:background="?android:attr/selectableItemBackground" />
</LinearLayout>